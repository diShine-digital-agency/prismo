# Runtime binaries (downloaded during setup)
runtime/
engine/

# Credentials and config
config/

# Session logs and reports (generated at runtime)
toolkit/logs/
toolkit/reports/

# Client profiles (may contain sensitive data)
toolkit/clients/*.json

# SHA256 checksums (generated during setup)
SHA256SUMS

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Temporary files
*.tmp
*.bak
*.swp
*~

# Editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
